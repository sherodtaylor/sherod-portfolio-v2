---
import { loadConfig } from '../lib/config';

const { personal, contact } = loadConfig();
// /now status moved to the top TmuxBar; no need to duplicate here.
---
<header>
  <h1>{personal.name}</h1>
  <p class="role muted">
    {personal.title} · {personal.location}
  </p>
  <ul class="contact" aria-label="Contact links">
    <li><a href={`mailto:${contact.email}`}>{contact.email}</a></li>
    <li><a href={contact.github} rel="me">github</a></li>
    <li><a href={contact.linkedin} rel="me">linkedin</a></li>
    <li><a href={`${import.meta.env.BASE_URL}/resume.pdf`}>resume</a></li>
  </ul>
</header>

<style>
  header { margin-bottom: var(--space-12); }
  .role { margin-top: var(--space-2); margin-bottom: var(--space-4); }
  .contact {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1) var(--space-4);
  }
  .contact li { margin: 0; }
</style>
