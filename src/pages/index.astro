---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Pane from '../components/Pane.astro';
import { loadConfig } from '../lib/config';
import { getCollection } from 'astro:content';

const { personal, experience, projects, skills } = loadConfig();

const technicalArticles = (await getCollection('articles'))
  .filter((a) => a.data.technical)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<BaseLayout pageType="home">
  <Header />

  <Pane label="About">
    <!--
      About paragraph from config.yaml — also feeds the PDF resume.
      Edit personal.description there; both surfaces update on deploy.
    -->
    <p>{personal.description}</p>
  </Pane>

  <Pane label="Experience">
    {experience.positions.map((p, i) => (
      <article class={`sub-pane role ${i === 0 ? 'role--lead' : 'role--compact'}`}>
        <h3>
          {p.role}{' '}<span class="muted">·</span>{' '}
          {p.company_url ? <a href={p.company_url}>{p.company}</a> : p.company}
        </h3>
        <p class="meta muted">{p.period} · {p.location}</p>
        {i === 0 && p.description && <p>{p.description}</p>}
        {i === 0 && p.achievements && p.achievements.length > 0 && (
          <ul>
            {p.achievements.map((a) => <li>{a}</li>)}
          </ul>
        )}
        {i !== 0 && p.description && <p class="muted">{p.description}</p>}
      </article>
    ))}
  </Pane>

  <Pane label="Selected projects">
    {projects.items.map((proj) => (
      <article class="sub-pane project">
        <h3>
          <a href={proj.link.href}>{proj.name}</a>
          {proj.website && (
            <>{' '}<span class="muted">·</span>{' '}<a href={proj.website.href}>{proj.website.label}</a></>
          )}
        </h3>
        <p>{proj.description}</p>
        {proj.highlights && proj.highlights.length > 0 && (
          <ul>
            {proj.highlights.map((h) => <li>{h}</li>)}
          </ul>
        )}
      </article>
    ))}
  </Pane>

  <Pane label="Skills">
    <dl class="skills">
      {skills.categories.map((cat) => (
        <>
          <dt>{cat.title}</dt>
          <dd>{cat.skills.map((s) => s.name).join(' · ')}</dd>
        </>
      ))}
    </dl>
  </Pane>

  {technicalArticles.length > 0 && (
    <Pane label="Writing">
      <ul class="writing">
        {technicalArticles.map((a) => (
          <li>
            <time datetime={a.data.date.toISOString()}>{a.data.date.toISOString().slice(0, 10)}</time>{' '}
            <a href={`${import.meta.env.BASE_URL}/articles/${a.slug}`}>{a.data.title}</a>
          </li>
        ))}
      </ul>
      <p class="muted small">
        Non-technical posts live in <a href={`${import.meta.env.BASE_URL}/archive`}>/archive</a>.
      </p>
    </Pane>
  )}

  <Footer slot="footer" />
</BaseLayout>

<style>
  /* Sub-pane — second-level tmux pane inside a parent Pane. Same border
     treatment, no inset label (the H3 inside is the title). Margin
     stack between sub-panes; last one flush to parent's bottom padding. */
  .sub-pane {
    border: 1px solid var(--border);
    padding: var(--space-4) var(--space-5);
    margin: 0 0 var(--space-4);
  }
  .sub-pane:last-child { margin-bottom: 0; }
  .sub-pane h3 { margin-bottom: var(--space-2); }

  .role h3 { margin-bottom: var(--space-1); }
  .role .meta { font-size: var(--fs-small); margin-bottom: var(--space-3); }
  .role--compact .meta { margin-bottom: 0; }

  .skills { margin: 0; }
  .skills dt { font-weight: 700; margin-top: var(--space-4); }
  .skills dt:first-child { margin-top: 0; }
  .skills dd { margin: 0 0 0; color: var(--fg-muted); }

  .writing { list-style: none; padding: 0; }
  .writing li { margin-bottom: var(--space-2); }
  .writing time { color: var(--fg-muted); font-size: var(--fs-small); margin-right: var(--space-2); }
  .small { font-size: var(--fs-small); }
</style>
