---
/*
 * Tmux-style status bar across the top of every page.
 *
 * Borrows the agent-smith TmuxStatusBar shape (brackets, middot
 * separators, all-mono) and keeps it restrained per SOUL.md:
 *   - text only, no animations, no blinking cursor
 *   - no fake terminal prompts ("$ cd /projects" → banned)
 *   - functional content only: site label, /now status, theme toggle
 *
 * If you find yourself adding ASCII art, color stripes, or a marquee
 * here — stop. That's the kitsch line SOUL.md draws.
 */
import { getCollection } from 'astro:content';
import { loadConfig } from '../lib/config';

interface Props { sessionName?: string; }
const { sessionName = '0:home' } = Astro.props;

const nowEntries = await getCollection('now');
const status = nowEntries[0]?.data.oneliner ?? '';
const openToWork = loadConfig().personal.openToWork === true;

// Parse session name into [prefix, label]. Map known labels back to
// routes so the part inside the brackets renders as a clickable link.
// "0:home" → prefix "0", label "home" → linked to BASE_URL/.
const sessionParts = sessionName.split(':');
const sessionPrefix = sessionParts.length > 1 ? sessionParts.slice(0, -1).join(':') : '';
const sessionLabel = sessionParts[sessionParts.length - 1] ?? sessionName;
const routeMap: Record<string, string> = {
  home: '',
  now: '/now',
  archive: '/archive',
};
const sessionHref = sessionLabel in routeMap
  ? `${import.meta.env.BASE_URL}${routeMap[sessionLabel]}`
  : null;
---
<div class="tmux-bar" role="banner">
  <span class="left">
    <span class="bracket">[</span>{sessionPrefix && (<>{sessionPrefix}<span class="bracket">:</span></>)}{sessionHref ? <a href={sessionHref} class="bar-link">{sessionLabel}</a> : sessionLabel}<span class="bracket">]</span>
  </span>
  <span class="right">
    {status && (
      <span class="status">
        <a href={`${import.meta.env.BASE_URL}/now`} class="bar-link">now</a>
        <span class="bracket"> · </span>
        <span class="oneliner">{status}</span>
      </span>
    )}
    {openToWork && (
      <span class="open" title="Open to new opportunities" aria-label="Open to new opportunities">
        <span class="open-dot" aria-hidden="true">●</span>
        <span class="open-label">open to work</span>
      </span>
    )}
    <button
      id="theme-toggle"
      type="button"
      aria-label="Toggle theme (click to switch)"
      title="Toggle theme"
    >
      <!-- Label shows current mode ("dark" / "light"); clicking flips it.
           Server-renders "dark" because dark is the default; the inline
           script in <head> rewrites it on cold load when localStorage
           holds a saved preference, so the visible label always matches
           the actual data-theme attribute. -->
      <span class="bracket">[</span><span class="theme-label" data-theme-label>dark</span><span class="bracket">]</span>
    </button>
  </span>
</div>

<script is:inline>
  (() => {
    const btn = document.getElementById('theme-toggle');
    if (!btn) return;
    const label = btn.querySelector('[data-theme-label]');
    const sync = () => {
      const current = document.documentElement.getAttribute('data-theme') || 'dark';
      if (label) label.textContent = current;
    };
    sync();
    btn.addEventListener('click', () => {
      const current = document.documentElement.getAttribute('data-theme') || 'dark';
      const next = current === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', next);
      try { localStorage.setItem('theme', next); } catch { /* ignore */ }
      sync();
    });
  })();
</script>

<style>
  .tmux-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-4);
    background: var(--bg-elev);
    color: var(--fg-muted);
    font-family: var(--font-mono);
    font-size: var(--fs-small);
    padding: var(--space-2) var(--space-4);
    border-bottom: 1px solid var(--border);
    /* Span the viewport — looks like a real status bar, not a card. */
    margin: calc(var(--space-12) * -1) calc(var(--space-6) * -1) var(--space-12);
  }
  .left {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-shrink: 0;
  }
  .right {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    min-width: 0;       /* allow .status to shrink + ellipsize */
    flex: 1 1 auto;
    justify-content: flex-end;
  }
  .bracket { color: color-mix(in srgb, var(--fg-muted) 55%, transparent); }
  .status {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    overflow: hidden;
    min-width: 0;       /* required for text-overflow inside flex */
    flex: 0 1 auto;
  }
  .status .oneliner {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    color: var(--fg-muted);
  }
  /* Bar-internal links — accent color + subtle underline. Used for the
     session-label "home" inside [0:home] on the left and the /now anchor
     on the right. Same shape both sides so they read as a matched pair. */
  .bar-link {
    color: var(--accent);
    border-bottom: 1px solid color-mix(in srgb, var(--accent) 35%, transparent);
    flex-shrink: 0;
  }
  .bar-link:hover, .bar-link:focus-visible {
    border-bottom-color: var(--accent);
  }
  .muted { color: var(--fg-muted); }

  /* Availability dot — minimal status-line presence indicator. The dot
     itself is a soft positive-signal green (matches agent-smith's accent
     family); the label stays muted so the indicator reads as chrome,
     not a CTA. Hide the label on narrow screens — the dot + tooltip
     carry the meaning. */
  .open {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    flex-shrink: 0;
    color: var(--fg-muted);
  }
  .open-dot {
    color: #5fbf8d;
    font-size: 1.05em;
    line-height: 1;
  }
  @media (max-width: 640px) {
    .open-label { display: none; }
  }

  #theme-toggle {
    background: transparent;
    border: 0;
    color: var(--fg-muted);
    font-family: inherit;
    font-size: inherit;
    cursor: pointer;
    padding: 0;
    line-height: 1;
    flex-shrink: 0;
  }
  #theme-toggle:hover .theme-label,
  #theme-toggle:focus-visible .theme-label {
    color: var(--accent);
  }
  #theme-toggle:focus-visible { outline: none; }

  @media (max-width: 640px) {
    .tmux-bar {
      flex-wrap: wrap;
      margin: calc(var(--space-6) * -1) calc(var(--space-4) * -1) var(--space-6);
      padding: var(--space-2) var(--space-3);
    }
    .status { max-width: 100%; }
  }
</style>
