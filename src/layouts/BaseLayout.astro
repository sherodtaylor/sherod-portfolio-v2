---
import '../styles/global.css';
import { loadConfig } from '../lib/config';
import TmuxBar from '../components/TmuxBar.astro';

interface Props {
  title?: string;
  description?: string;
  pageType?: 'home' | 'page';
  /* Optional Article-shape metadata for /articles/[slug] — surfaces
     Schema.org Article JSON-LD so AI summarizers attribute the post
     correctly when they cite it. */
  article?: {
    title: string;
    description: string;
    date: Date;
    slug: string;
  };
}

const { title, description, pageType = 'page', article } = Astro.props;
const config = loadConfig();

const pageTitle = title
  ? `${title} — ${config.personal.name}`
  : `${config.personal.name} — ${config.personal.title}`;
const pageDescription = description ?? config.personal.description;

const canonicalUrl = new URL(Astro.url.pathname, 'https://sherodtaylor.dev').toString();

const personJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': 'https://sherodtaylor.dev/#person',
  name: config.personal.name,
  jobTitle: config.personal.title,
  description: config.personal.description,
  url: 'https://sherodtaylor.dev',
  email: `mailto:${config.contact.email}`,
  sameAs: [
    config.contact.github,
    config.contact.linkedin,
  ],
  knowsAbout: [
    'AI Platforms',
    'MCP',
    'Distributed Systems',
    'Kubernetes',
    'Platform Engineering',
    'Engineering Leadership',
    'API Architecture',
  ],
};

const websiteJsonLd = pageType === 'home' ? {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': 'https://sherodtaylor.dev/#website',
  name: `${config.personal.name} — ${config.personal.title}`,
  url: 'https://sherodtaylor.dev',
  description: config.personal.description,
  inLanguage: 'en',
  author: { '@id': 'https://sherodtaylor.dev/#person' },
  publisher: { '@id': 'https://sherodtaylor.dev/#person' },
} : null;

const articleJsonLd = article ? {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: article.title,
  description: article.description,
  datePublished: article.date.toISOString(),
  dateModified: article.date.toISOString(),
  author: { '@id': 'https://sherodtaylor.dev/#person' },
  publisher: { '@id': 'https://sherodtaylor.dev/#person' },
  url: canonicalUrl,
  mainEntityOfPage: canonicalUrl,
  inLanguage: 'en',
} : null;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}/favicon.svg`} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" title={`${config.personal.name} — Writing`} href={`${import.meta.env.BASE_URL}/articles/feed.xml`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Geist+Mono:wght@400;500;700&display=swap" />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content={pageType === 'home' ? 'website' : 'article'} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary" />

    <script type="application/ld+json" set:html={JSON.stringify(personJsonLd)}></script>
    {websiteJsonLd && <script type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)}></script>}
    {articleJsonLd && <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd)}></script>}

    <!--
      Theme precedence: localStorage saved preference → OS prefers-color-scheme
      → fallback to dark (SOUL.md default). Applied inline before paint to
      avoid a flash. Both APIs gracefully degrade if blocked or unsupported.
    -->
    <script is:inline>
      (() => {
        let theme = null;
        try {
          const saved = localStorage.getItem('theme');
          if (saved === 'light' || saved === 'dark') theme = saved;
        } catch { /* localStorage blocked */ }
        if (!theme && typeof window.matchMedia === 'function') {
          if (window.matchMedia('(prefers-color-scheme: light)').matches) {
            theme = 'light';
          } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
            theme = 'dark';
          }
        }
        if (theme) document.documentElement.setAttribute('data-theme', theme);
        // If still no theme, leave the default in tokens.css alone (dark).
      })();
    </script>
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <TmuxBar />
    <main id="main">
      <slot />
    </main>
    <slot name="footer" />
  </body>
</html>
