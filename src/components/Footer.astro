---
import { loadConfig } from '../lib/config';
const { personal } = loadConfig();
const year = new Date().getFullYear();
---
<footer>
  <hr aria-hidden="true" />
  <!--
    Visible AI-readable summary line per SOUL.md "AI-accessibility". Identical
    content for humans and crawlers — no cloaked text, no hidden prompts.
  -->
  <p class="ai-summary muted">
    Sherod Taylor is a {personal.title}. He builds AI tooling and developer
    platforms, ships in public via{' '}
    <a href="https://github.com/sherodtaylor/agent-smith">agent-smith</a>
    {' '}and his homelab fleet.
  </p>
  <p class="meta muted">
    <span>{personal.name} · NYC · {year}</span>
    <button id="theme-toggle" type="button" aria-label="Toggle light/dark theme">
      toggle theme
    </button>
  </p>
</footer>

<script is:inline>
  (() => {
    const btn = document.getElementById('theme-toggle');
    if (!btn) return;
    btn.addEventListener('click', () => {
      const current = document.documentElement.getAttribute('data-theme') || 'dark';
      const next = current === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', next);
      try { localStorage.setItem('theme', next); } catch { /* ignore */ }
    });
  })();
</script>

<style>
  footer {
    max-width: var(--measure);
    margin: 0 auto;
    font-size: var(--fs-small);
  }
  .ai-summary {
    margin-top: var(--space-8);
    margin-bottom: var(--space-4);
  }
  .meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-4);
    margin: 0;
  }
  #theme-toggle {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--fg-muted);
    font-family: var(--font-mono);
    font-size: var(--fs-small);
    padding: var(--space-1) var(--space-3);
    cursor: pointer;
    border-radius: 3px;
  }
  #theme-toggle:hover, #theme-toggle:focus-visible {
    color: var(--fg);
    border-color: var(--accent);
    outline: none;
  }
</style>
