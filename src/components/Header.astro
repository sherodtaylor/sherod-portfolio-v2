---
import { loadConfig } from '../lib/config';

const { personal, contact } = loadConfig();

// One-line status pulled from /now content. The /now page owns the longer
// body; the home page surfaces just the lead line.
import { getCollection } from 'astro:content';
const nowEntries = await getCollection('now');
const nowEntry = nowEntries[0];
const status = nowEntry?.data.oneliner;
---
<header>
  <h1>{personal.name}</h1>
  <p class="role muted">
    {personal.title} · {personal.location}
  </p>
  <ul class="contact" aria-label="Contact links">
    <li><a href={`mailto:${contact.email}`}>{contact.email}</a></li>
    <li><a href={contact.github} rel="me">github</a></li>
    <li><a href={contact.linkedin} rel="me">linkedin</a></li>
    <li><a href={`${import.meta.env.BASE_URL}/resume.pdf`}>resume</a></li>
  </ul>
  {status && (
    <p class="now">
      <a href={`${import.meta.env.BASE_URL}/now`}>now</a>{' '}<span class="muted">·</span>{' '}{status}
    </p>
  )}
</header>

<style>
  header { margin-bottom: var(--space-12); }
  .role { margin-top: var(--space-2); margin-bottom: var(--space-4); }
  .contact {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1) var(--space-4);
  }
  .contact li { margin: 0; }
  .now { margin-top: var(--space-4); font-size: var(--fs-small); }
</style>
