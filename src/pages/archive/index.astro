---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const nonTechnicalArticles = (await getCollection('articles'))
  .filter((a) => !a.data.technical)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<BaseLayout title="archive" description="Older non-technical posts" sessionName="2:archive">
  <p class="back"><a href={import.meta.env.BASE_URL}>← home</a></p>
  <h1>archive</h1>
  <p class="muted">
    Older non-technical posts. Not linked from the home page; lives here so
    the links keep working.
  </p>
  {nonTechnicalArticles.length === 0 ? (
    <p>Nothing yet.</p>
  ) : (
    <ul class="archive">
      {nonTechnicalArticles.map((a) => (
        <li>
          <time datetime={a.data.date.toISOString()}>{a.data.date.toISOString().slice(0, 10)}</time>{' '}
          <a href={`${import.meta.env.BASE_URL}/articles/${a.slug}`}>{a.data.title}</a>
        </li>
      ))}
    </ul>
  )}
  <Footer slot="footer" />
</BaseLayout>

<style>
  .back { font-size: var(--fs-small); margin-bottom: var(--space-6); }
  .archive { list-style: none; padding: 0; margin-top: var(--space-6); }
  .archive li { margin-bottom: var(--space-2); }
  .archive time { color: var(--fg-muted); font-size: var(--fs-small); margin-right: var(--space-2); }
</style>
