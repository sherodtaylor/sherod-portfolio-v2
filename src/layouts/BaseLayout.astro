---
import '../styles/global.css';
import { loadConfig } from '../lib/config';
import TmuxBar from '../components/TmuxBar.astro';

interface Props {
  title?: string;
  description?: string;
  pageType?: 'home' | 'page';
  sessionName?: string;
}

const { title, description, pageType = 'page', sessionName } = Astro.props;
const config = loadConfig();

const pageTitle = title
  ? `${title} — ${config.personal.name}`
  : `${config.personal.name} — ${config.personal.title}`;
const pageDescription = description ?? config.personal.description;

const personJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: config.personal.name,
  jobTitle: config.personal.title,
  description: config.personal.description,
  url: 'https://sherodtaylor.dev',
  email: `mailto:${config.contact.email}`,
  sameAs: [
    config.contact.github,
    config.contact.linkedin,
  ],
  knowsAbout: [
    'AI Platforms',
    'MCP',
    'Distributed Systems',
    'Kubernetes',
    'Platform Engineering',
    'Engineering Leadership',
    'API Architecture',
  ],
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}/favicon.svg`} />
    <link rel="canonical" href={new URL(Astro.url.pathname, 'https://sherodtaylor.dev').toString()} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;600;700&display=swap" />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content={pageType === 'home' ? 'website' : 'article'} />
    <meta property="og:url" content={new URL(Astro.url.pathname, 'https://sherodtaylor.dev').toString()} />
    <meta name="twitter:card" content="summary" />

    <script type="application/ld+json" set:html={JSON.stringify(personJsonLd)}></script>

    <!--
      Theme precedence: localStorage saved preference → OS prefers-color-scheme
      → fallback to dark (SOUL.md default). Applied inline before paint to
      avoid a flash. Both APIs gracefully degrade if blocked or unsupported.
    -->
    <script is:inline>
      (() => {
        let theme = null;
        try {
          const saved = localStorage.getItem('theme');
          if (saved === 'light' || saved === 'dark') theme = saved;
        } catch { /* localStorage blocked */ }
        if (!theme && typeof window.matchMedia === 'function') {
          if (window.matchMedia('(prefers-color-scheme: light)').matches) {
            theme = 'light';
          } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
            theme = 'dark';
          }
        }
        if (theme) document.documentElement.setAttribute('data-theme', theme);
        // If still no theme, leave the default in tokens.css alone (dark).
      })();
    </script>
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <TmuxBar sessionName={sessionName} />
    <main id="main">
      <slot />
    </main>
    <slot name="footer" />
  </body>
</html>
