---
/*
 * Tmux-style status bar across the top of every page.
 *
 * Borrows the agent-smith TmuxStatusBar shape (brackets, middot
 * separators, all-mono) and keeps it restrained per SOUL.md:
 *   - text only, no animations, no blinking cursor
 *   - no fake terminal prompts ("$ cd /projects" → banned)
 *   - functional content only: nav (home/now/writing), /now oneliner,
 *     availability dot, theme toggle
 *
 * The left side is a real nav now — each bracketed "window" is a link
 * to the matching route, the active one is accent-highlighted. The
 * right side carries the /now oneliner status + availability + theme.
 *
 * If you find yourself adding ASCII art, color stripes, or a marquee
 * here — stop. That's the kitsch line SOUL.md draws.
 */
import { getCollection } from 'astro:content';
import { loadConfig } from '../lib/config';

const nowEntries = await getCollection('now');
const status = nowEntries[0]?.data.oneliner ?? '';
const openToWork = loadConfig().personal.openToWork === true;

// Nav model: every page renders the same three windows. The active one
// is computed from the current pathname (after stripping BASE_URL),
// matching tmux's "current window" highlight.
const base = import.meta.env.BASE_URL.replace(/\/+$/, '');
const path = Astro.url.pathname.replace(new RegExp(`^${base}`), '') || '/';

// "writing" routes to the Writing pane anchor on home — that's where the
// engineering essays live (per index.astro's Writing pane, id pane-writing).
// `/archive` is intentionally NOT in the nav: per SOUL.md it's the
// off-brand bin and is not linked from home. Active matches an article
// read view; home stays "home" even when scrolled to #pane-writing
// (hash changes don't shift the active register).
const nav = [
  { idx: 0, label: 'home',    href: `${base}/`,               match: (p: string) => p === '/' },
  { idx: 1, label: 'now',     href: `${base}/now`,            match: (p: string) => p.startsWith('/now') },
  { idx: 2, label: 'writing', href: `${base}/#pane-writing`,  match: (p: string) => p.startsWith('/articles') },
];
---
<div class="tmux-bar" role="banner">
  <nav class="left" aria-label="Primary">
    {nav.map((item) => {
      const active = item.match(path);
      return (
        <a
          href={item.href}
          class:list={['nav-item', { 'is-active': active }]}
          aria-current={active ? 'page' : undefined}
        ><span class="bracket">[</span><span class="idx">{item.idx}</span><span class="bracket">:</span><span class="label">{item.label}</span><span class="bracket">]</span></a>
      );
    })}
  </nav>
  <span class="right">
    {status && (
      <span class="status">
        <span class="oneliner">{status}</span>
      </span>
    )}
    {openToWork && (
      <span
        class="open"
        title="Open to platform engineering conversations"
        aria-label="Open to platform engineering conversations"
      >
        <span class="open-dot" aria-hidden="true">●</span>
        <span class="open-label">available</span>
      </span>
    )}
    <button
      id="theme-toggle"
      type="button"
      aria-label="Toggle theme (click to switch)"
      title="Toggle theme"
    >
      <!-- Label shows current mode ("dark" / "light"); clicking flips it.
           Server-renders "dark" because dark is the default; the inline
           script in <head> rewrites it on cold load when localStorage
           holds a saved preference, so the visible label always matches
           the actual data-theme attribute. -->
      <span class="bracket">[</span><span class="theme-label" data-theme-label>dark</span><span class="bracket">]</span>
    </button>
  </span>
</div>

<script is:inline>
  (() => {
    const btn = document.getElementById('theme-toggle');
    if (!btn) return;
    const label = btn.querySelector('[data-theme-label]');
    const sync = () => {
      const current = document.documentElement.getAttribute('data-theme') || 'dark';
      if (label) label.textContent = current;
    };
    sync();
    btn.addEventListener('click', () => {
      const current = document.documentElement.getAttribute('data-theme') || 'dark';
      const next = current === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', next);
      try { localStorage.setItem('theme', next); } catch { /* ignore */ }
      sync();
    });
  })();
</script>

<style>
  .tmux-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-4);
    background: var(--bg-elev);
    color: var(--fg-muted);
    font-family: var(--font-mono);
    font-size: var(--fs-small);
    padding: var(--space-2) var(--space-4);
    border-bottom: 1px solid var(--border);
    /* Span the viewport — looks like a real status bar, not a card. */
    margin: calc(var(--space-12) * -1) calc(var(--space-6) * -1) var(--space-12);
  }
  .left {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-shrink: 0;
  }
  .right {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    min-width: 0;       /* allow .status to shrink + ellipsize */
    flex: 1 1 auto;
    justify-content: flex-end;
  }
  .bracket { color: color-mix(in srgb, var(--fg-muted) 55%, transparent); }

  /* Nav item — entire `[0:home]` bracketed label is one anchor. Inline
     spans flow tight (no flex gaps) so the bracket label reads as a
     single unit. Inactive items are muted; the active window gets the
     accent treatment, matching tmux's current-window highlight. */
  .nav-item {
    display: inline-block;
    color: var(--fg-muted);
    text-decoration: none;
    padding: 0;
    white-space: nowrap;
  }
  .nav-item:hover,
  .nav-item:focus-visible {
    color: var(--fg);
  }
  .nav-item:focus-visible { outline: none; }
  .nav-item.is-active {
    color: var(--accent);
    border-bottom: 1px solid color-mix(in srgb, var(--accent) 35%, transparent);
  }
  .nav-item.is-active .bracket {
    color: color-mix(in srgb, var(--accent) 55%, transparent);
  }

  .status {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    overflow: hidden;
    min-width: 0;       /* required for text-overflow inside flex */
    flex: 0 1 auto;
  }
  .status .oneliner {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    color: var(--fg-muted);
  }
  .muted { color: var(--fg-muted); }

  /* Availability dot — tmux-status presence indicator. Single-word
     label "available" keeps the tmux register; tooltip carries the
     longer brand-voice sentence. */
  .open {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    flex-shrink: 0;
    color: var(--fg-muted);
    cursor: help;
  }
  .open-dot {
    color: #5fbf8d;
    font-size: 1.05em;
    line-height: 1;
  }
  @media (max-width: 640px) {
    .open-label { display: none; }
  }

  #theme-toggle {
    background: transparent;
    border: 0;
    color: var(--fg-muted);
    font-family: inherit;
    font-size: inherit;
    cursor: pointer;
    padding: 0;
    line-height: 1;
    flex-shrink: 0;
  }
  #theme-toggle:hover .theme-label,
  #theme-toggle:focus-visible .theme-label {
    color: var(--accent);
  }
  #theme-toggle:focus-visible { outline: none; }

  @media (max-width: 640px) {
    .tmux-bar {
      flex-wrap: wrap;
      margin: calc(var(--space-6) * -1) calc(var(--space-4) * -1) var(--space-6);
      padding: var(--space-2) var(--space-3);
    }
    .status { max-width: 100%; }
  }
</style>
