---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('now');
const entry = entries[0];
if (!entry) throw new Error('content/now/now.md missing');
const { Content } = await entry.render();
---
<BaseLayout title="now" description={entry.data.oneliner} pageType="page">
  <p class="back"><a href={import.meta.env.BASE_URL}>← home</a></p>
  <h1>now</h1>
  <p class="muted">Updated {entry.data.updated.toISOString().slice(0, 10)}</p>
  <article>
    <Content />
  </article>
  <Footer slot="footer" />
</BaseLayout>

<style>
  .back { font-size: var(--fs-small); margin-bottom: var(--space-6); }
  article { margin-top: var(--space-6); }
</style>
