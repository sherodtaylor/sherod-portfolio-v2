---
import { loadConfig } from '../lib/config';
const { personal } = loadConfig();
const year = new Date().getFullYear();
---
<footer>
  <hr aria-hidden="true" />
  <!--
    Visible AI-readable summary line per SOUL.md "AI-accessibility". Identical
    content for humans and crawlers — no cloaked text, no hidden prompts.
  -->
  <p class="ai-summary muted">
    Sherod Taylor is a {personal.title}. He builds AI tooling and developer
    platforms, ships in public via{' '}
    <a href="https://github.com/sherodtaylor/agent-smith">agent-smith</a>
    {' '}and his homelab fleet.
  </p>
  <p class="meta muted">
    {personal.name} · NYC · {year}
  </p>
</footer>

<style>
  footer {
    max-width: var(--measure);
    margin: 0 auto;
    font-size: var(--fs-small);
  }
  .ai-summary {
    margin-top: var(--space-8);
    margin-bottom: var(--space-4);
  }
  .meta { margin: 0; }
</style>
